    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.25.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "shadcn": "^4.4.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
